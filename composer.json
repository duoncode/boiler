{
	"name": "duon/boiler",
	"description": "A PHP template engine that doesn't require you to learn a new syntax",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@duon.run"
		}
	],
	"homepage": "https://duon.run/boiler",
	"keywords": ["duon", "templating", "templates"],
	"autoload": {
		"psr-4": {
			"Duon\\Boiler\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Duon\\Boiler\\Tests\\": "tests"
		}
	},
	"require": {
		"php": "^8.5"
	},
	"require-dev": {
		"duon/dev": "^3.0",
		"symfony/html-sanitizer": "^8.0"
	},
	"suggest": {
		"symfony/html-sanitizer": "Provides Boiler's built-in HTML sanitizer"
	},
	"scripts": {
		"test": [
			"./vendor/bin/phpunit --testdox --no-coverage --colors=always"
		],
		"types": "./vendor/bin/psalm --no-cache",
		"mdlint": "markdownlint-cli2 README.md CHANGELOG.md LICENSE.md docs/",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"coverage": [
			"php -d xdebug.mode=coverage ./vendor/bin/phpunit --testdox --path-coverage --coverage-text --coverage-php=.coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer .coverage/cover.php"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer types",
			"composer mdlint"
		],
		"benchmark": "php bench/run.php"
	}
}
